# ===== Ports =====
FRONTEND_PORT=80
BACKEND_PORT=8000
MONGO_PORT=27017

# ===== MongoDB Root =====
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-this-password

# ===== App DB =====
DB_NAME=super_app_madrasah
MONGO_URL=mongodb://admin:change-this-password@mongodb:27017/super_app_madrasah?authSource=admin

# ===== Security =====
JWT_SECRET=change-this-jwt-secret-min-32-chars

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost,http://localhost:80

# ===== Service URLs =====
SERVICE_URL_BACKEND=http://localhost:8000
SERVICE_FQDN_BACKEND=localhost
SERVICE_URL_FRONTEND=http://localhost
SERVICE_FQDN_FRONTEND=localhost
