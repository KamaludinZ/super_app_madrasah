# ── Database ──────────────────────────────────────────────────
# MongoDB Atlas (SRV format) atau self-hosted
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=super_app_madrasah

# ── Keamanan ─────────────────────────────────────────────────
# Ganti dengan secret yang kuat di production!
JWT_SECRET=ganti-dengan-secret-yang-panjang-dan-acak

# ── CORS ─────────────────────────────────────────────────────
# Daftar domain yang diizinkan, pisahkan dengan koma
# Contoh: https://app.sekolah.id,https://www.sekolah.id
# Gunakan * untuk semua (tidak disarankan di production)
CORS_ORIGINS=*

# ── Port (opsional, default 80) ───────────────────────────────
FRONTEND_PORT=80
