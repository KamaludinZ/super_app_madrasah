# ============================================================
# SUPER APPS MATSANDATAMA - Environment Variables Template
# ============================================================
# Untuk Coolify: Set variables ini di Coolify UI → Environment Variables
# Untuk Local Dev: Copy file ini ke .env dan isi dengan nilai yang sesuai

# ============================================================
# ✅ REQUIRED - Database Configuration
# ============================================================

# MongoDB Connection String
#
# Format MongoDB Atlas (Cloud - Rekomendasi):
# mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
#
# Format MongoDB Self-Hosted:
# mongodb://username:password@host:27017/database?authSource=admin
#
# Contoh lengkap:
# MONGO_URL=mongodb+srv://admin_madrasah:MyStrongPass123@super-app-cluster.abc123.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Nama database (default: super_app_madrasah)
DB_NAME=super_app_madrasah

# ============================================================
# ✅ REQUIRED - Security
# ============================================================

# JWT Secret Key (MINIMUM 32 characters)
#
# Generate dengan salah satu cara:
# 1. openssl rand -hex 32
# 2. python3 -c "import secrets; print(secrets.token_hex(32))"
# 3. https://www.uuidgenerator.net/guid (ambil 2x GUID tanpa dash, gabung)
#
# Contoh hasil:
# JWT_SECRET=a8f5f167f44f4964e6c998dee827110c3a8c724f8f6b3a1b3f5f0e9e7c8d6a5b
JWT_SECRET=ganti-dengan-secret-yang-panjang-minimum-32-karakter

# ============================================================
# ⚪ OPTIONAL - CORS Configuration
# ============================================================

# Allowed CORS Origins
# Development: gunakan *
# Production: specify domain, pisahkan dengan koma
#
# Contoh:
# CORS_ORIGINS=https://app.your-domain.com,https://www.your-domain.com
CORS_ORIGINS=*

# ============================================================
# ⚪ OPTIONAL - Service URLs (untuk email, webhooks, dll)
# ============================================================

# Backend Service URL (full URL with protocol)
# Contoh: https://api.your-domain.com
SERVICE_URL_BACKEND=

# Backend Fully Qualified Domain Name
# Contoh: api.your-domain.com
SERVICE_FQDN_BACKEND=

# Frontend Service URL (dalam single deployment, sama dengan backend)
# Contoh: https://app.your-domain.com
SERVICE_URL_FRONTEND=

# Frontend FQDN
# Contoh: app.your-domain.com
SERVICE_FQDN_FRONTEND=
